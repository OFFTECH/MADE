{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskState",
  "description": "Serialized task state for agent handoff between sessions",
  "type": "object",
  "required": ["task_id", "status", "created_at", "assigned_agent"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]+$",
      "description": "Unique task identifier (e.g., VIV-042)"
    },
    "parent_task_id": {
      "type": ["string", "null"],
      "description": "Parent task if this is a subtask from decomposition"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "blocked", "review", "testing", "completed", "failed"],
      "description": "Current task lifecycle stage"
    },
    "assigned_agent": {
      "type": "string",
      "enum": ["orchestrator", "numerics", "infrastructure", "interface_io", "test_verification", "review"],
      "description": "Agent role responsible for this task"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string",
      "description": "Human-readable task description"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of conditions that must be met for task completion"
    },
    "branch": {
      "type": ["string", "null"],
      "description": "Git branch for this task's work"
    },
    "files_modified": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Files changed during this task"
    },
    "files_created": {
      "type": "array",
      "items": { "type": "string" },
      "description": "New files created during this task"
    },
    "decisions_made": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "decision": { "type": "string" },
          "rationale": { "type": "string" },
          "adr_id": { "type": ["string", "null"] }
        }
      },
      "description": "Architectural or design decisions made during this task"
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Unresolved questions for handoff to next agent or human"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Task IDs this task depends on"
    },
    "blocked_by": {
      "type": ["string", "null"],
      "description": "If blocked, what is blocking this task"
    },
    "test_results": {
      "type": "object",
      "properties": {
        "unit": { "type": "string", "enum": ["pass", "fail", "skip", "pending"] },
        "integration": { "type": "string", "enum": ["pass", "fail", "skip", "pending"] },
        "verification": { "type": "string", "enum": ["pass", "fail", "skip", "pending"] },
        "regression": { "type": "string", "enum": ["pass", "fail", "skip", "pending"] }
      }
    },
    "review_result": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pending", "pass", "fail", "pass_with_comments"] },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "severity": { "type": "string", "enum": ["blocker", "major", "minor", "comment"] },
              "category": { "type": "string" },
              "description": { "type": "string" },
              "file": { "type": "string" },
              "line": { "type": "integer" }
            }
          }
        }
      }
    },
    "context_notes": {
      "type": "string",
      "description": "Free-form notes for the next agent picking up this task"
    },
    "iteration_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of agent iterations on this task"
    }
  }
}
